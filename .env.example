# Copy this file to .env and fill in your values
# Then set the token in config.js or use: DISCORD_TOKEN=your_token node bot.js
DISCORD_TOKEN=your_bot_token_here

# Optional: comma-separated Discord user IDs that may use bot commands.
# If unset, all users can use commands (subject to Discord permission checks).
# ADMIN_USER_IDS=123456789012345678,987654321098765432
